Cell[BoxData[{
 RowBox[{
  RowBox[{"rules", "=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"c___", "\[CenterDot]", 
       RowBox[{"\[Gamma]", "[", "a_", "]"}], "\[CenterDot]", 
       RowBox[{"\[Gamma]", "[", "b_", "]"}], "\[CenterDot]", "d___"}], ":>", 
      RowBox[{
       RowBox[{"c", "\[CenterDot]", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"-", 
            RowBox[{"\[Gamma]", "[", "b", "]"}]}], "\[CenterDot]", 
           RowBox[{"\[Gamma]", "[", "a", "]"}]}], "+", 
          RowBox[{"2", 
           RowBox[{"g", "[", 
            RowBox[{"a", ",", "b"}], "]"}]}]}], ")"}], "\[CenterDot]", "d"}], 
       "/;", 
       RowBox[{"Not", "@", 
        RowBox[{"OrderedQ", "[", 
         RowBox[{"{", 
          RowBox[{"a", ",", "b"}], "}"}], "]"}]}]}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"c___", "\[CenterDot]", 
       RowBox[{"\[Gamma]", "[", "a_", "]"}], "\[CenterDot]", 
       RowBox[{"\[Gamma]", "[", "a_", "]"}], "\[CenterDot]", "d___"}], ":>", 
      RowBox[{"c", "\[CenterDot]", 
       RowBox[{"(", 
        RowBox[{"g", "[", 
         RowBox[{"a", ",", "a"}], "]"}], ")"}], "\[CenterDot]", "d"}]}]}], 
    "\[IndentingNewLine]", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"GammaAlgebra", "[", "exp_", "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"exp", "//.", "rules"}], "//", "Simplify"}], ")"}]}]}], "Input",
 CellChangeTimes->{{3.9850850356839333`*^9, 3.985085069573634*^9}},
