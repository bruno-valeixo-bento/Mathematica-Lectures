Cell[BoxData[
 RowBox[{
  RowBox[{"f", "[", "x_", "]"}], ":=", 
  RowBox[{
   RowBox[{"100", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       FractionBox["1", 
        RowBox[{
         SqrtBox[
          RowBox[{"2", "\[Pi]"}]], "\[Sigma]"}]], 
       RowBox[{"Exp", "[", 
        RowBox[{"-", 
         FractionBox[
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"x", "-", "\[Mu]"}], ")"}], "2"], 
          RowBox[{"2", 
           SuperscriptBox["\[Sigma]", "2"]}]]}], "]"}]}], "-", 
      RowBox[{
       FractionBox["1", 
        RowBox[{
         SqrtBox[
          RowBox[{"2", "\[Pi]"}]], "\[Sigma]"}]], 
       RowBox[{"Exp", "[", 
        RowBox[{"-", 
         FractionBox[
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"x", "+", "\[Mu]"}], ")"}], "2"], 
          RowBox[{"2", 
           SuperscriptBox["\[Sigma]", "2"]}]]}], "]"}]}]}], ")"}]}], "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Mu]", "->", "1"}], ",", 
     RowBox[{"\[Sigma]", "->", 
      RowBox[{"1", "/", "10"}]}]}], "}"}]}]}]], "Input",
