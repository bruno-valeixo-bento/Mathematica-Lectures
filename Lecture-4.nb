Cell[BoxData[{
 RowBox[{"Clear", "[", "f", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f", "[", 
   RowBox[{"x_", "?", "NumberQ"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"x", "^", "2"}], "/", "2"}], "+", 
   RowBox[{"Cos", "[", "x", "]"}], "-", "1"}]}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"f", "[", "x", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{
         RowBox[{"-", "5"}], " ", 
         SuperscriptBox["10", 
          RowBox[{"-", "4"}]]}], ",", 
        RowBox[{"5", " ", 
         SuperscriptBox["10", 
          RowBox[{"-", "4"}]]}]}], "}"}], ",", 
      RowBox[{"PlotRange", "->", 
       RowBox[{"{", 
        RowBox[{"0", ",", 
         RowBox[{"3", " ", 
          SuperscriptBox["10", 
           RowBox[{"-", "15"}]]}]}], "}"}]}], ",", 
      RowBox[{"WorkingPrecision", "->", 
       RowBox[{"#", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"#", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}], "&"}], "/@", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"MachinePrecision", ",", "Black"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"25", ",", "Red"}], "}"}]}], "}"}]}], "]"}]}], "Input",
