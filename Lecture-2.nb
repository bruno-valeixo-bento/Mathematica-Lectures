 CellLabel->"In[5]:=",ExpressionUUID->"1a86ecaf-5002-41be-8af1-96a3f644aa2a"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "tograph", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tograph", "[", "term_", "]"}], ":=", 
  RowBox[{"Graph", "[", 
   RowBox[{
    RowBox[{"Sort", "@", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"List", "@@", "term"}], "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
          RowBox[{
           RowBox[{"\[Phi]", "[", 
            SubscriptBox["k", "a_"], "]"}], ",", 
           RowBox[{"\[Phi]", "[", 
            SubscriptBox["k", "b_"], "]"}]}], "\[RightAngleBracket]"}], ":>", 
         
         RowBox[{
          RowBox[{"a", "[", 
           RowBox[{"[", "0", "]"}], "]"}], "<->", 
          RowBox[{"b", "[", 
           RowBox[{"[", "0", "]"}], "]"}]}]}], "}"}]}], ")"}]}], ",", 
    RowBox[{"VertexLabels", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"_", "?", "IntegerQ"}], "->", "Automatic"}], "}"}]}], ",", 
    RowBox[{"BaseStyle", "->", "Black"}], ",", 
    RowBox[{"ImageSize", "->", "200"}]}], "]"}]}]}], "Input",
