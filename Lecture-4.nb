      "{\"C\", \"planck mass\"} -> {\"PhysicalConstant\", \"dflt\"}", 
      "Values" -> {{
        "name" -> "PhysicalConstant", "desc" -> "a physical constant", 
         "input" -> "{\"C\", \"planck mass\"} -> {\"PhysicalConstant\"}"}, {
        "name" -> "Unit", "desc" -> "a unit", "input" -> 
         "{\"C\", \"planck mass\"} -> {\"Unit\"}"}}}}, "assumptions" -> {}, 
