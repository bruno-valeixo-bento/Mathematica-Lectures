Cell[CellGroupData[{

Cell["Kernels", "Subsection",
 CellChangeTimes->{{3.9869011628678007`*^9, 
  3.98690116364399*^9}},ExpressionUUID->"d3f90742-9dd0-4ac1-bbdb-\
75bd0ddc4c74"],

Cell["\<\
Different notebooks running on the same Kernel are just different windows to \
the same thing. 
If Notebook1.nb and Notebook2.nb are using the same Kernel, definition you \
make in Notebook1.nb exist also in Notebook2.nb.\
\>", "Text",
 CellChangeTimes->{{3.98690116570408*^9, 3.986901318960681*^9}, {
  3.986901379431994*^9, 
  3.986901380680325*^9}},ExpressionUUID->"0ba83deb-24e4-47e4-a4a9-\
8ff2b485b2d4"],

Cell[TextData[{
 StyleBox["E.g: ",
  FontWeight->"Bold"],
 "\[LineSeparator]",
 StyleBox["Notebook1.nb  ",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"c", "=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f7342184-d57c-4276-95ad-32fa1d40771e"],
 "; \n",
 StyleBox["Notebook2.nb",
  FontSlant->"Italic"],
 "   ",
 Cell[BoxData[
  FormBox["c", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5ef1921b-1b8e-436b-bba6-c060b2f7434f"],
 " \n",
 StyleBox["                              ",
  FontSlant->"Italic"],
 "   ",
 Cell[BoxData[
  FormBox["1", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6b3d44d0-8d36-4cd3-8e33-8afc1dd697c7"],
 " "
}], "Text",
 CellChangeTimes->{3.98690138870187*^9},
 Background->RGBColor[
  0.4, 0.6, 1, 0.33],ExpressionUUID->"d586edb5-f97e-4b0b-b1dc-fe7c9ef3322f"],

Cell[TextData[{
 "If you want them to be independent, change the Kernel of Notebook2.nb, \n",
 StyleBox["Evaluation > Notebook\[CloseCurlyQuote]s Kernel > \
\[OpenCurlyDoubleQuote]other Kernel\[CloseCurlyDoubleQuote]",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.986901328263969*^9, 
  3.986901368986435*^9}},ExpressionUUID->"f601cc05-b53f-41ac-9b45-\
