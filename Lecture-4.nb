Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"WorkingPrecision", " ", "->", " ", "MachinePrecision"}], 
   TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"17e21abe-f450-422e-99a5-dd596567bad2"],
 "  ",
 StyleBox["[16 digits, but untracked]",
  FontWeight->"Bold",
  FontColor->RGBColor[0.4, 0.6, 1]],
 "\n",
 "With MachinePrecision, Mathematica uses the usual floating-point hardware \
(i.e. as if you were using Doubles in other languages).\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"WorkingPrecision", " ", "->", " ", "n"}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"847936e6-ec6c-4245-92e1-403c07346383"],
 "   ",
 StyleBox["[",
  FontWeight->"Bold",
  FontColor->RGBColor[0.4, 0.6, 1]],
 StyleBox["n",
  FontWeight->"Bold",
  FontSlant->"Italic",
  FontColor->RGBColor[0.4, 0.6, 1]],
 StyleBox[" digits, fully tracked]",
  FontWeight->"Bold",
  FontColor->RGBColor[0.4, 0.6, 1]],
 "\nWith an explicit value, Mathematica uses its own ",
 StyleBox["software-implemented",
  FontSlant->"Italic"],
 " arbitrary precision arithmetic (i.e. it keeps an estimate of \
significance/error; it does ",
 StyleBox["extra work",
  FontSlant->"Italic"],
 " to make sure you\[CloseCurlyQuote]re satisfying your precision \
requirements; keep in mind that this also means it can be slower)."
}], "Text",
 CellChangeTimes->{{3.985669670287373*^9, 3.9856698928684397`*^9}, {
  3.9856699789945717`*^9, 3.9856700396196823`*^9}, {3.985785617025579*^9, 
  3.985785628252242*^9}},
 Background->GrayLevel[
  0.85],ExpressionUUID->"c20183f6-a621-4ecc-8db9-a152b3eabd72"],

Cell[TextData[{
 "The warning of FindMinimum was not a WorkingPrecision problem; it was \
Mathematica telling us that it did ",
 StyleBox["not",
  FontSlant->"Italic"],
 " track the precision with its extra software, so it cannot guarantee that \
AccuracyGoal and PrecisionGoal were met. "
}], "Text",
 CellChangeTimes->{{3.985785525454878*^9, 
  3.985785607161791*^9}},ExpressionUUID->"b009be50-a27e-4658-ac9c-\
2a56039a5489"]
}, Closed]],

Cell[CellGroupData[{

Cell["Kernels ", "Section",
 CellChangeTimes->{{3.98560152623741*^9, 
  3.985601531443953*^9}},ExpressionUUID->"e8aa9631-71ed-49c0-bc6f-\
5421d97b9b6f"],

Cell[TextData[{
 "Different notebooks doesn\[CloseCurlyQuote]t necessarily mean different ",
 StyleBox["Kernels",
  FontWeight->"Bold"],
 ". \nBy default, they all ",
 StyleBox["run on the same Kernel",
  FontWeight->"Bold"],
 "--think of different \[OpenCurlyQuote]windows\[CloseCurlyQuote] to the same \
\[OpenCurlyQuote]computing center\[CloseCurlyQuote]. "
}], "Text",
 CellChangeTimes->{{3.9856015344107122`*^9, 3.985601600768302*^9}},
 Background->GrayLevel[
  0.85],ExpressionUUID->"b13e3453-858e-4097-8247-b867e36f9fcb"],

Cell[TextData[{
 "To ",
 StyleBox["create",
  FontWeight->"Bold",
  FontColor->RGBColor[0.4, 0.6, 1]],
 " separate Kernels: ",
 StyleBox["Evaluation",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"->", " "}], TraditionalForm]],ExpressionUUID->
  "0a9e211e-0f77-4a35-bdc7-1b92d7eb849b"],
 StyleBox["Kernel Configuration Options ",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{{3.985601629147213*^9, 
  3.985601688850555*^9}},ExpressionUUID->"0754ed4f-00e2-438f-a130-\
f71e6922d5d6"],

Cell[TextData[{
 "To ",
 StyleBox["change",
  FontWeight->"Bold",
  FontColor->RGBColor[0.4, 0.6, 1]],
 " notebook\[CloseCurlyQuote]s Kernel: ",
 StyleBox["Evaluation ",
  FontSlant->"Italic"],
 Cell[BoxData[
  FormBox[
   RowBox[{"->", " "}], TraditionalForm]],
  FontSlant->"Italic",ExpressionUUID->
  "857e3dc9-e0f8-44c5-a781-30d40d2c463d"],
 StyleBox["Notebook\[CloseCurlyQuote]s Kernel",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"->", " "}], TraditionalForm]],ExpressionUUID->
  "2ac5fb1f-42a8-4e48-af9c-687c2eb4085b"],
 "[Select Kernel]"
}], "Text",
 CellChangeTimes->{{3.9856017120798473`*^9, 
  3.9856017706700373`*^9}},ExpressionUUID->"b8c34f05-d9af-499d-8ea0-\
4e189c851bbb"],

Cell[TextData[{
 "To ",
 StyleBox["quit",
  FontWeight->"Bold",
  FontColor->RGBColor[0.4, 0.6, 1]],
 " specific Kernel: ",
 StyleBox["Evaluation ",
  FontSlant->"Italic"],
 Cell[BoxData[
  FormBox["->", TraditionalForm]],
  FontSlant->"Italic",ExpressionUUID->
  "f598bba2-e848-40e6-a0a0-a00acbb73463"],
 StyleBox[" Quit Kernel",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["->", TraditionalForm]],ExpressionUUID->
  "2283439e-1b40-4717-9753-844252411bf8"],
 " [Select Kernel]"
}], "Text",
 CellChangeTimes->{{3.9856017922324038`*^9, 
  3.985601823036921*^9}},ExpressionUUID->"649b5ee6-1fd3-4e02-bc3d-\
ea588ebc5f70"],

Cell[TextData[{
 "It is also useful to know how to ",
 StyleBox["abort",
  FontWeight->"Bold",
  FontColor->RGBColor[0.4, 0.6, 1]],
 " an Evaluation: ",
 StyleBox["Evaluation ",
  FontSlant->"Italic"],
 Cell[BoxData[
  FormBox[
   RowBox[{"->", " "}], TraditionalForm]],
  FontSlant->"Italic",ExpressionUUID->
  "1764c307-5fba-44a7-a6f0-fed216179acb"],
 StyleBox["Abort Evaluation ",
  FontSlant->"Italic"],
 "(shortcut: ",
 StyleBox["Cmd + .",
  FontWeight->"Bold"],
 ")"
}], "Text",
 CellChangeTimes->{{3.985601842859192*^9, 
  3.985601955227029*^9}},ExpressionUUID->"1b787bf2-cc27-4daf-a6b3-\
7d213e4381f1"],

Cell[TextData[{
 "We will see later how to use different Kernels to run computations in ",
 StyleBox["Parallel",
  FontWeight->"Bold"],
 ". "
}], "Text",
 CellChangeTimes->{{3.9857856488901577`*^9, 
  3.985785661998211*^9}},ExpressionUUID->"4f18617f-bf50-4749-b5cd-\
87087e59d025"]
}, Closed]],

Cell[CellGroupData[{

Cell["Working with Data", "Section",
 CellChangeTimes->{{3.985602039645565*^9, 
  3.98560204200949*^9}},ExpressionUUID->"69e0ef55-73a8-43e3-9e9f-\
a7b886db32bd"],

Cell[BoxData[
 RowBox[{"Quit", "[", "]"}]], "Input",
 CellChangeTimes->{{3.985681033870099*^9, 3.985681034352982*^9}},
 CellLabel->
  "In[170]:=",ExpressionUUID->"da47646b-2cab-4f9e-9b09-d5ee877614cf"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"y", "[", "t_", "]"}], ":=", 
   RowBox[{"y0", "+", 
    RowBox[{"v0", " ", "t"}], "-", 
    RowBox[{
     FractionBox["1", "2"], "g", " ", 
     SuperscriptBox["t", "2"]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"par", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"y0", "->", "0"}], ",", 
     RowBox[{"v0", "->", "10"}], ",", 
     RowBox[{"g", "->", "9.8"}]}], "}"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.985678583994158*^9, 3.9856786195504513`*^9}},
 CellLabel->"In[28]:=",ExpressionUUID->"9c5771a3-deea-445e-abfa-4e0f30048a38"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  TemplateBox[<|"query" -> "earth gravity", "boxes" -> RowBox[{
       TemplateBox[{"\"Earth\"", 
         RowBox[{"Entity", "[", 
           RowBox[{"\"Planet\"", ",", "\"Earth\""}], "]"}], 
         "\"Entity[\\\"Planet\\\", \\\"Earth\\\"]\"", "\"planet\""}, 
        "Entity"], "[", 
       TemplateBox[{"\"gravity\"", 
         RowBox[{"EntityProperty", "[", 
           RowBox[{"\"Planet\"", ",", "\"Gravity\""}], "]"}], 
         "\"EntityProperty[\\\"Planet\\\", \\\"Gravity\\\"]\""}, 
        "EntityProperty"], "]"}], 
    "allassumptions" -> {{
      "word" -> "", "template" -> 
       "Assuming \"earth\" is a planet${separator}Use the input as ${desc} or \
${desc} or ${desc} instead", "count" -> "4", "pulldown" -> "false", "type" -> 
       "MultiClash", "default" -> "{\"MC\", \"\"} -> {\"Planet\", \"dflt\"}", 
       "Values" -> {{
         "name" -> "Planet", "desc" -> "a planet", "input" -> 
          "{\"MC\", \"\"} -> {{\"Planet\", \"a planet\"}}", "word" -> 
          "earth"}, {
         "name" -> "Unit", "desc" -> "a unit", "input" -> 
          "{\"MC\", \"\"} -> {\"Unit\"}", "word" -> "the input"}, {
         "name" -> "GeogravityWord", "desc" -> " referring to gravity", 
          "input" -> "{\"MC\", \"\"} -> {\"GeogravityWord\"}", "word" -> 
          "the input"}, {
         "name" -> "Formula", "desc" -> "a formula", "input" -> 
          "{\"MC\", \"\"} -> {\"Formula\"}", "word" -> "the input"}}}}, 
    "assumptions" -> {}, "open" -> {1, 2}, 
    "querystate" -> {
     "Online" -> True, "Allowed" -> True, "mparse.jsp" -> 
      1.443756`6.611038795588627, "Messages" -> {}}, "contextinfo" -> 
    Automatic, "version" -> 5|>,
   "LinguisticAssistantTemplate"], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"you", " ", "can", " ", "access", " ", 
     RowBox[{"Wolfram", "'"}], 
     RowBox[{"s", " ", "'"}], 
     RowBox[{"knowledge", "'"}], " ", "with", " ", 
     StyleBox["Ctrl",
      FontWeight->"Bold"]}], 
    StyleBox["+=",
     FontWeight->"Bold"]}], 
   StyleBox[" ",
    FontWeight->"Bold"], "*)"}]}]], "Input",
 CellChangeTimes->{
  3.98568814293478*^9, {3.985785702112512*^9, 
   3.985785735880912*^9}},ExpressionUUID->"c8d7f748-6bb3-446b-83ee-\
9dba8ece14de"],

Cell[BoxData[
 TemplateBox[{"9.8`3.", 
   RowBox[{"\"m\"", "\[InvisibleSpace]", "\"/\"", "\[InvisibleSpace]", 
     SuperscriptBox["\"s\"", "2"]}], "meters per second squared", 
   FractionBox["\"Meters\"", 
    SuperscriptBox["\"Seconds\"", "2"]]},
  "Quantity"]], "Output",
