Cell[TextData[{
 "Package files end with ",
 StyleBox[".wl",
  FontWeight->"Bold"],
 "; inside they look very much like typical Mathematica notebooks. This is \
because they simply collect Mathematica code that gets ",
 StyleBox["imported ",
  FontWeight->"Bold"],
 "in a notebook when you load it. \nLet us look at the ",
 StyleBox["poker.wl",
  FontWeight->"Bold"],
 " package.",
 " "
}], "Text",
 CellChangeTimes->{{3.986274170509439*^9, 3.986274213378339*^9}, {
  3.9862742439269037`*^9, 3.986274284987815*^9}},
 Background->RGBColor[
  0.4, 0.6, 1, 0.33],ExpressionUUID->"3b8a3cbc-8a76-4d02-a58d-b6c8d4755cb3"],

Cell[BoxData[
 RowBox[{"SystemOpen", "[", "\"\<poker.wl\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.9860075870111847`*^9, 3.986007591338729*^9}},
 CellLabel->"In[93]:=",ExpressionUUID->"6a717351-073f-4d6f-92a1-29bd369e590e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Directory", "[", "]"}]], "Input",
 CellChangeTimes->{{3.986012956663986*^9, 3.986012957637097*^9}},
 CellLabel->"In[35]:=",ExpressionUUID->"a7362c78-fb13-45d8-8f2b-d3eeb0291eab"],

Cell[BoxData["\<\"/Users/brunovaleixobento/Library/CloudStorage/OneDrive-\
UniversidadedeLisboa/Madrid/IFT/Mathematica Lectures/Lectures\"\>"], "Output",\

 CellChangeTimes->{{3.986012958047099*^9, 3.986012973682485*^9}},
 CellLabel->"Out[35]=",ExpressionUUID->"dbacdfcb-b68f-4972-969c-d9653bfa0fee"]
}, Open  ]],

Cell[TextData[{
 "To load the package we use the usual ",
 Cell[BoxData[
  FormBox[
   RowBox[{"<<", "poker`"}], TraditionalForm]],
  FormatType->TraditionalForm,
  FontWeight->"Bold",ExpressionUUID->"9e095b6c-854f-4efe-bef0-1b2f2a1c58d3"],
 "command. \nThere are two options: either the package is saved in a specific \
",
 StyleBox["directory",
  FontSlant->"Italic"],
 " and you use ",
 StyleBox["SetDirectory[",
  FontWeight->"Bold"],
 StyleBox["directory",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox["] ",
  FontWeight->"Bold"],
 "to make the package accessible to the notebook; or you save the package in \
the ",
 StyleBox["Applications",
  FontWeight->"Bold"],
 " directory, as we\[CloseCurlyQuote]ve seen above, and it is accessible by \
default.  "
}], "Text",
 CellChangeTimes->{{3.986274170509439*^9, 3.986274213378339*^9}, {
  3.9862742439269037`*^9, 3.986274284987815*^9}, {3.986274950151697*^9, 
  3.9862750081424294`*^9}, {3.9862750534916487`*^9, 3.986275142875885*^9}},
 Background->RGBColor[
  0.4, 0.6, 1, 0.33],ExpressionUUID->"6156d8ff-3dc3-4411-b780-35a6ac3204d6"],

Cell[BoxData[
 RowBox[{"<<", "poker`"}]], "Input",
 CellChangeTimes->{{3.986012961075385*^9, 3.986012963806931*^9}},
 CellLabel->"In[96]:=",ExpressionUUID->"81e97c14-d784-4756-88e4-08c7369972e6"],

