\\!\\(\\*RowBox[{\\\"x\\\"}]\\) near \\!\\(\\*RowBox[{\\\"{\\\", \\\"x\\\", \
\\\"}\\\"}]\\) = \\!\\(\\*RowBox[{\\\"{\\\", \\\"1.0390003334378706`\\\", \
\\\"}\\\"}]\\). NIntegrate obtained \\!\\(\\*RowBox[{\\\"-\\\", \
\\\"1.7763568394002505`*^-15\\\"}]\\) and \
\\!\\(\\*RowBox[{\\\"2.9842833687289576`*^-14\\\"}]\\) for the integral and \
error estimates.\"", 2, 228, 29, 32046126624261550694, "Local"},
