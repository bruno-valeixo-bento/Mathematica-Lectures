  TemplateBox[{
    Cell[
     TextData["AccuracyGoal"]], "paclet:ref/AccuracyGoal"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",
  FontSize->14,ExpressionUUID->"571d7576-0a3b-4745-bddb-9a461e82a90c"],
 " effectively specifies the ",
 StyleBox["absolute error",
  FontWeight->"Bold",
  FontVariations->{"Underline"->True}],
 StyleBox[" ",
  FontSize->16,
  FontWeight->"Bold"],
 "allowed in a numerical procedure. \n",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["PrecisionGoal"]], "paclet:ref/PrecisionGoal"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",
  FontSize->14,ExpressionUUID->"c86d642b-3026-4b09-bfe1-ac3abe8f5c2f"],
 " effectively specifies the ",
 StyleBox["relative error",
  FontWeight->"Bold",
  FontVariations->{"Underline"->True},
  FontColor->GrayLevel[0]],
 StyleBox[" ",
  FontColor->GrayLevel[0]],
 "allowed in a numerical procedure. \n\n",
