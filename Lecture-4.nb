Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", "f", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f", "[", "x_", "]"}], ":=", 
  RowBox[{"Sin", "[", 
   SuperscriptBox["x", "2"], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"FindMinimum", "[", 
  RowBox[{
   RowBox[{"f", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "2"}], "}"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FindMinimum", "[", 
   RowBox[{
    RowBox[{"f", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "2"}], "}"}], ",", 
    RowBox[{"AccuracyGoal", "\[Rule]", "18"}], ",", 
    RowBox[{"PrecisionGoal", "\[Rule]", "20"}]}], "]"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{
     "error", " ", Cell[
      "\[LessEqual] ",ExpressionUUID->"dcfc554c-f8e1-443a-897e-507aac20d400"], 
      SuperscriptBox["10", 
       RowBox[{"-", "18"}]]}], " ", "+", " ", 
     RowBox[{"x", "\[CenterDot]", 
      SuperscriptBox["10", 
       RowBox[{"-", "20"}]]}]}], " ", ";", " ", 
    RowBox[{"WorkingPrecision", "->", "MachinePrecision"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FindMinimum", "[", 
   RowBox[{
    RowBox[{"f", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "2"}], "}"}], ",", 
    RowBox[{"AccuracyGoal", "\[Rule]", "18"}], ",", 
    RowBox[{"PrecisionGoal", "\[Rule]", "20"}], ",", 
    RowBox[{"WorkingPrecision", "->", "5"}]}], "]"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"WorkingPrecision", " ", "<", " ", "MachinePrecision"}], ",", " ", 
    RowBox[{"but", " ", "now", " ", "it", " ", 
     RowBox[{"doesn", "'"}], "t", " ", 
     RowBox[{"complain", "--"}], 
     RowBox[{"why", "?", "!"}]}]}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.98566900274236*^9, 3.9856690457968683`*^9}, {
