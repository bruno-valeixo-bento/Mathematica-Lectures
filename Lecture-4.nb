  FontSize->14],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["PrecisionGoal"]], "paclet:ref/PrecisionGoal"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "->", 
