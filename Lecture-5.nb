   (Grid[#, Alignment -> Left, Spacings -> {2, 2}, Frame -> All, 
    Background -> {None, {None, LightGray, LightGray}}]& )[{{
      (Grid[#, Spacings -> {1, 1}]& )[
       Table[
        Flatten[{
          Style["Player " <> ToString[Poker`Private`i] <> ":", 
           If[Poker`Private`player == Poker`Private`i, {Bold, Red}, {Plain}]], 
          Poker`Private`hand[Poker`Private`i]}], {Poker`Private`i, 3}]]}, {
      ButtonBar[{
       "Play" :> Poker`Private`play, "Fold" :> Poker`Private`fold, "New Game" :> 
        Poker`NewGame[3]}, ImageSize -> 80]}}], StandardForm],
