Cell[BoxData[{
 RowBox[{"ClearAll", "[", "vertex", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"vertex", "[", "n_", "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"a", "=", 
      RowBox[{"Unique", "[", "a", "]"}]}], "}"}], ",", 
    RowBox[{"Product", "[", 
     RowBox[{
      RowBox[{"\[Phi]", "[", 
       SubscriptBox["k", 
        RowBox[{"a", "[", "i", "]"}]], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}]}], "]"}]}]}], "Input",\

