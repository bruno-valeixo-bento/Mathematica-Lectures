Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"?", "AccuracyGoal"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "normally", " ", "equal", " ", "to", " ", "half", " ", "the", " ", 
    "setting", " ", "for", " ", 
    TemplateBox[{
      Cell[
       TextData["WorkingPrecision"]], "paclet:ref/WorkingPrecision"},
     "RefLink",
     BaseStyle->{"InlineFormula"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"In", " ", "most", " ", "cases"}], ",", 
    RowBox[{"you", " ", "must", " ", "set", " ", 
     TemplateBox[{
       RowBox[{
         Cell["WorkingPrecision"], " "}], "paclet:ref/WorkingPrecision"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "to", " ", "be", " ", "at", " ", "least",
      " ", "as", " ", "large", " ", "as", " ", 
     TemplateBox[{
       Cell[
        TextData["AccuracyGoal"]], "paclet:ref/AccuracyGoal"},
      "RefLink",
      BaseStyle->{"InlineFormula"}]}]}], "*)"}]}]}], "Input",
