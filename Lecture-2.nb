Cell[BoxData[{
 RowBox[{"ClearAll", "[", "wick", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"wick", "[", "X_Times", "]"}], ":=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", "}"}], ",", 
     RowBox[{
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
          RowBox[{
           RowBox[{"X", "[", 
            RowBox[{"[", "1", "]"}], "]"}], ",", 
           RowBox[{"X", "[", 
            RowBox[{"[", "j", "]"}], "]"}]}], "\[RightAngleBracket]"}], 
         RowBox[{"wick", "[", 
          RowBox[{"Drop", "[", 
           RowBox[{
            RowBox[{"Drop", "[", 
             RowBox[{"X", ",", 
              RowBox[{"{", "j", "}"}]}], "]"}], ",", 
            RowBox[{"{", "1", "}"}]}], "]"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "2", ",", 
          RowBox[{"Length", "[", "X", "]"}]}], "}"}]}], "]"}], "//", 
      "Expand"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"wick", "[", 
   RowBox[{
    RowBox[{"\[Phi]", "[", "a_", "]"}], 
    RowBox[{"\[Phi]", "[", "b_", "]"}]}], "]"}], ":=", 
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    RowBox[{"\[Phi]", "[", "a", "]"}], ",", 
    RowBox[{"\[Phi]", "[", "b", "]"}]}], "\[RightAngleBracket]"}]}]}], "Input",\

 CellChangeTimes->{{3.9852555198165493`*^9, 3.985255611456427*^9}, {
  3.985255666704776*^9, 3.985255676797649*^9}, {3.9852557120475273`*^9, 
